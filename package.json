{
  "name": "bedrock-engineer",
  "version": "1.15.3",
  "description": "Autonomous software development agent apps using Amazon Bedrock, capable of customize to create/edit files, execute commands, search the web, use knowledge base, use multi-agents, generative images and more.",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/daisuke-awaji/bedrock-engineer",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watchAll  --config jest.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:integration:watch": "jest --config jest.integration.config.js --watchAll",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac --universal",
    "sign": "codesign --force --deep --sign - /path/to/YourApp.dmg",
    "sign:mac": "codesign --force --deep --sign - \"/Applications/Bedrock Engineer.app\"",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.782.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.782.0",
    "@aws-sdk/client-bedrock-runtime": "^3.821.0",
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/client-sts": "3.830.0",
    "@aws-sdk/client-translate": "^3.825.0",
    "@aws-sdk/credential-providers": "^3.772.0",
    "@codemirror/autocomplete": "6.18.6",
    "@codesandbox/sandpack-react": "2.20.0",
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "3.0.0",
    "@headlessui/react": "^2.2.0",
    "@iconify-json/logos": "1.2.4",
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@monaco-editor/react": "^4.6.0",
    "@reactour/tour": "3.8.0",
    "@tshepomgaga/aws-sfn-graph": "0.0.6",
    "axios": "^1.9.0",
    "chart.js": "^4.4.8",
    "cors": "2.8.5",
    "diff": "6.0.0",
    "electron-store": "8.2.0",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "fix-path": "^4.0.0",
    "flowbite-react": "0.11.8",
    "framer-motion": "11.3.29",
    "i18next": "23.15.0",
    "lodash": "^4.17.21",
    "lottie-react": "2.4.1",
    "mermaid": "11.6.0",
    "node-cache": "5.1.2",
    "react-chartjs-2": "^5.3.0",
    "react-cmdk": "1.3.9",
    "react-drawio": "^1.0.3",
    "react-hot-toast": "2.5.2",
    "react-i18next": "15.5.3",
    "react-icons": "5.5.0",
    "react-markdown": "9.0.1",
    "react-resizable-panels": "^2.1.7",
    "react-router": "6.26.1",
    "react-router-dom": "6.26.1",
    "react-syntax-highlighter": "15.6.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "^6.0.0",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "vite-plugin-svgr": "4.3.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "1.0.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@smithy/types": "4.3.1",
    "@types/diff": "5.2.3",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.14.8",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "10.4.21",
    "dotenv": "^16.4.5",
    "electron": "36.5.0",
    "electron-builder": "24.13.3",
    "electron-vite": "3.1.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react": "^7.37.5",
    "flowbite": "^3.1.2",
    "jest": "29.7.0",
    "postcss": "8.5.6",
    "prettier": "3.5.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.10",
    "ts-jest": "29.4.0",
    "typescript": "5.8.3",
    "vite": "^6.3.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.44.0",
    "@rollup/rollup-win32-x64-msvc": "4.44.0",
    "dmg-license": "1.0.11"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  }
}
